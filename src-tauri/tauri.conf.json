{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Ready",
  "version": "0.4.0",
  "identifier": "com.samsung.airready",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AI Ready — 사내 AI 환경 설정 도우미",
        "width": 1200,
        "height": 760,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true,
        "decorations": false,
        "center": true,
        "shadow": true,
        "backgroundColor": "#f3f5f7"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
